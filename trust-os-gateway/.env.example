# TrustOS Gateway Environment Variables

# Server
PORT=4166
NODE_ENV=development
LOG_LEVEL=info

# CORS
CORS_ORIGIN=*

# Internal Service Token (for downstream service communication)
INTERNAL_SERVICE_TOKEN=your-secure-internal-token-here

# Downstream Services (update URLs to match your deployment)

# Fraud Detection Services
FRAUD_SERVICE_URL=http://localhost:3001
FRAUD_AGENT_URL=http://localhost:3007

# Identity Services
UNIFIED_IDENTITY_URL=http://localhost:4060
IDENTITY_SERVICE_URL=http://localhost:4000

# Consent/GDPR Service
GDPR_SERVICE_URL=http://localhost:3005
