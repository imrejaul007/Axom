# BuzzLocal App Environment Variables
# Copy this file to .env and update values

# Backend Service URLs (local development)
EXPO_PUBLIC_SOCIETY_SERVICE_URL=http://localhost:4019
EXPO_PUBLIC_SAFETY_SERVICE_URL=http://localhost:4017
EXPO_PUBLIC_ASK_SERVICE_URL=http://localhost:4015
EXPO_PUBLIC_AGENCY_SERVICE_URL=http://localhost:4018
EXPO_PUBLIC_COMMUNITY_SERVICE_URL=http://localhost:4004
EXPO_PUBLIC_FEED_SERVICE_URL=http://localhost:4000

# For physical devices, use your machine's local IP
# Run: ifconfig | grep "inet " to find your IP

# For production
# EXPO_PUBLIC_SOCIETY_SERVICE_URL=https://api.buzzlocal.app
